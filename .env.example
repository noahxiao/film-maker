# Used by the AI SDK Gateway provider during local development.
# On Vercel, OIDC can be used instead of a long-lived API key.
AI_GATEWAY_API_KEY=

# Optional local OIDC token fetched by Vercel tooling.
VERCEL_OIDC_TOKEN=

# Cloudflare R2 storage for uploaded references and generated videos.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Optional object-key organization.
R2_PROJECT_PREFIX=projects/film-maker
R2_ENVIRONMENT=development

# Optional S3 endpoint override for jurisdiction-specific buckets.
# Default: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
