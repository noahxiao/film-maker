# Used by the AI SDK Gateway provider during local development.
# On Vercel, OIDC can be used instead of a long-lived API key.
AI_GATEWAY_API_KEY=

# Optional local OIDC token fetched by Vercel tooling.
VERCEL_OIDC_TOKEN=

# Required so uploaded image/video/audio references can be hosted for Seedance.
BLOB_READ_WRITE_TOKEN=
